# Copy this file to `.env.local` (or your deploy provider's env config) and
# fill in real values before going live. All variables are optional — when
# unset, the newsletter / contact forms gracefully fall back to a mailto:
# draft addressed to VITE_CONTACT_EMAIL (default: hello@voyager.press).

# Newsletter subscription endpoint. Receives POST { email, source? }.
# Examples: Buttondown, ConvertKit, Mailchimp form action, or your own API.
VITE_NEWSLETTER_ENDPOINT=

# Contact form submission endpoint. Receives POST { name, email, subject, message }.
# Examples: Formspree, Resend, Web3Forms, or your own API.
VITE_CONTACT_FORM_ENDPOINT=

# Primary contact email used in mailto: fallbacks and Contact Us copy.
VITE_CONTACT_EMAIL=hello@voyager.press
